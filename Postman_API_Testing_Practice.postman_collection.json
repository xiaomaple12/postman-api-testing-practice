    {
      "name": "06 GET - Authorization Header",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Authorization header is sent correctly\", function () {\r",
              "    const response = pm.response.json();\r",
              "    const token = pm.environment.get(\"token\");\r",
              "    pm.expect(response.headers.authorization).to.eql(\"Bearer \" + token);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
