  },
  "item": [
    {
      "name": "02 POST - Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response name is Amy\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.json.name).to.eql(\"Bob\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response has email field\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.json).to.have.property(\"email\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response email is correct\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.json.email).to.eql(\"amy@gmail.com\");\r",
              "});\r",
              "\r",
              "pm.test(\"Save name to environment variable\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.environment.set(\"userName\", response.json.name);\r",
              "});\r",
              "\r",
              "pm.test(\"Save email to environment variable\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.environment.set(\"userEmail\", response.json.email);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Amy\",\r\n  \"email\": \"amy@gmail.com\",\r\n  \"status\": \"active\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/post",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "post"
          ]
        }
      },
      "response": []
    },
    {
      "name": "01 GET - Query Params",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Query param name matches userName variable\", function () {\r",
              "    const response = pm.response.json();\r",
              "    const userName = pm.environment.get(\"userName\");\r",
              "    pm.expect(response.args.name).to.eql(userName);\r",
              "});\r",
              "\r",
              "pm.test(\"Query param status is active\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.args.status).to.eql(\"active\");\r",
              "});\r",
              "\r",
              "pm.test(\"Query param email matches userEmail variable\", function () {\r",
              "    const response = pm.response.json();\r",
              "    const userEmail = pm.environment.get(\"userEmail\");\r",
              "    pm.expect(response.args.email).to.eql(userEmail);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/get?name={{userName}}&status=active&email={{userEmail}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "get"
          ],
          "query": [
            {
              "key": "name",
              "value": "{{userName}}"
            },
            {
              "key": "status",
              "value": "active"
            },
            {
              "key": "email",
              "value": "{{userEmail}}"
            }
          ]
        }
      },
      "response": []
    },
