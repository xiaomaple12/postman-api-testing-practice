          "script": {
            "exec": [
              "const randomNumber = Math.floor(Math.random() * 100000);\r",
              "const randomEmail = \"test\" + randomNumber + \"@gmail.com\";\r",
              "\r",
              "pm.environment.set(\"randomEmail\", randomEmail);"
            ],
